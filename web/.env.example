# Copy to .env.local for local dev. For GitHub Pages, set these as Secrets and inject at build (see README).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: override GitHub Pages base path (default in vite.config is /gonggudao/)
# VITE_BASE_PATH=/gonggudao/
